VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# Firebase Admin SDK Credentials (pour le script de génération automatique)
# Pour obtenir ces credentials:
# 1. Allez sur Firebase Console: https://console.firebase.google.com/
# 2. Sélectionnez votre projet (wikilink-race)
# 3. Allez dans Project Settings > Service Accounts
# 4. Cliquez sur "Generate new private key"
# 5. Téléchargez le fichier JSON et extrayez les valeurs ci-dessous

FIREBASE_PROJECT_ID=wikilink-race
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@wikilink-race.iam.gserviceaccount.com
